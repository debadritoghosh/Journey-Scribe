{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User profile photo URL" },
        "isPremium": { "type": "boolean", "description": "Whether the user has a premium subscription" },
        "createdAt": { "type": "integer", "description": "Timestamp of profile creation" }
      },
      "required": ["uid", "email", "displayName", "isPremium", "createdAt"]
    },
    "Trip": {
      "title": "Trip",
      "description": "Travel itinerary and details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique trip ID" },
        "userId": { "type": "string", "description": "User ID who owns the trip" },
        "title": { "type": "string", "description": "Trip title" },
        "destination": { "type": "string", "description": "Trip destination" },
        "startDate": { "type": "string", "format": "date-time", "description": "Trip start date" },
        "endDate": { "type": "string", "format": "date-time", "description": "Trip end date" },
        "description": { "type": "string", "description": "Trip description" },
        "imageUrl": { "type": "string", "format": "uri", "description": "Trip cover image URL" },
        "budgetLevel": { "type": "string", "enum": ["Economy", "Standard", "Luxury"], "description": "Budget level" },
        "totalEstimatedPrice": { "type": "number", "description": "Total estimated price" },
        "createdAt": { "type": "integer", "description": "Timestamp of trip creation" },
        "itinerary": { "type": "array", "description": "List of itinerary items" },
        "aiAnalysis": { "type": "string", "description": "Professional AI analysis of the trip" },
        "stressScore": { "type": "number", "description": "Calculated stress score" },
        "weatherForecast": { "type": "object", "description": "Weather forecast data" },
        "budgetBreakdown": { "type": "object", "description": "Budget breakdown data" },
        "uniqueInsights": { "type": "object", "description": "Unique travel insights" },
        "bookingUrl": { "type": "string", "format": "uri", "description": "Booking URL" }
      },
      "required": ["id", "userId", "title", "destination", "startDate", "endDate", "createdAt"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "User journal entry for a trip",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique journal entry ID" },
        "tripId": { "type": "string", "description": "ID of the trip this entry belongs to" },
        "userId": { "type": "string", "description": "User ID who owns the entry" },
        "date": { "type": "string", "format": "date-time", "description": "Date of the entry" },
        "title": { "type": "string", "description": "Entry title" },
        "content": { "type": "string", "description": "Entry content" },
        "imageUrl": { "type": "string", "format": "uri", "description": "Entry image URL" },
        "createdAt": { "type": "integer", "description": "Timestamp of entry creation" }
      },
      "required": ["id", "tripId", "userId", "date", "title", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Trip document"
    },
    "/journals/{journalId}": {
      "schema": "JournalEntry",
      "description": "Journal entry document"
    }
  }
}
